{
    "name": "novay/feeder",
    "description": "Laravel client for Feeder API with automatic token caching, refresh, retry, safe logging, Artisan commands, multi connection, testing fake, and typed exceptions.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Novay\\Feeder\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/log": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Novay\\Feeder\\FeederServiceProvider"
            ],
            "aliases": {
                "Feeder": "Novay\\Feeder\\Facades\\Feeder"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}